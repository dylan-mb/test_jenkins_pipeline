pipeline {
    agent any

    parameters {
        choice(name: 'CLIENT', choices: ['agglo', 'rna'], description: 'Client to test')
    }

    environment { 
        PROD_ENV_FILE= """${sh(returnStdout: true, script: 'echo "client-config/${CLIENT}/.env.${CLIENT}.prod"')}"""
    }

    stages {
        stage('Hello') {
            steps {
                sh 'printenv'
                sh 'echo $PROD_ENV_FILE'
                sh 'cat $PROD_ENV_FILE | grep TARGET_SERVER | cut -d= -f2-'
                echo 'Hello World'
            }
        }
    }
}
