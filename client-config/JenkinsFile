pipeline {
    agent any

    parameters {
        choice(name: 'CLIENT', choices: ['agglo', 'rna'], description: 'Client to test')
    }

    stages {
        stage('Resolve environment file') {
            steps {
                script {
                    def envMap = [
                        rna:   [ 'RECETTE': 'rec', 'INTEG': 'integ' ],
                        bre:   [ 'RECETTE': 'rec', 'INTEG': 'integ' ],
                        agglo: [ 'RECETTE': 'staging', 'INTEG': 'integ' ]
                    ]
        
                    if (!envMap.containsKey(params.CLIENT)) {
                        error "Unknown client: ${params.CLIENT}"
                    }
        
                    def recetteEnv = envMap[params.CLIENT]['RECETTE']
        
                    if (!recetteEnv) {
                        error "No mapping for ${params.CLIENT} / RECETTE"
                    }


                    env.PROD_ENV_FILE = "client-config/${CLIENT}/.env.${CLIENT}.prod"
                    env.REC_ENV_FILE = "client-config/${params.CLIENT}/.env.${params.CLIENT}.${recetteEnv}"
                    env.INTEG_ENV_FILE = "client-config/${CLIENT}/.env.${CLIENT}.integ"
                }
            }
        }

        stage('Dump prod') {
            steps {
                script {
                    def loadEnvVars(file, keys) {
                        def pattern = keys.join('|')
                        def output = sh(
                            returnStdout: true,
                            script: "grep -E '^(${pattern})=' ${file}"
                        ).trim()
                    
                        output.split('\\n').each {
                            def (k, v) = it.split('=', 2)
                            env[k] = v
                        }
                    }
            
                loadEnvVars(env.PROD_ENV_FILE, ['TARGET_SERVER'])
            }
        }

        stage('Hello') {
            steps {
                sh 'echo $TARGET_SERVER'
                sh 'echo $INTEG_ENV_FILE'
                sh 'echo $REC_ENV_FILE'
                sh 'echo $PROD_ENV_FILE'
                sh 'cat $PROD_ENV_FILE | grep TARGET_SERVER | cut -d= -f2-'
                echo 'Hello World'
            }
        }
    }
}
